# Copy this file to ".env" in the same folder as docker-compose.yml.
# .env is gitignored; use strong values locally.

POSTGRES_USER=accounting_app
POSTGRES_PASSWORD=replace-with-a-long-random-secret
POSTGRES_DB=AI-accounting

# Optional if Postgres is not on localhost:5432
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Alternative: set full URLs instead of POSTGRES_* (SYNC optional; derived for Alembic if omitted)
# DATABASE_URL=postgresql+asyncpg://accounting_app:replace-with-a-long-random-secret@localhost:5432/AI-accounting
# SYNC_DATABASE_URL=postgresql+psycopg2://accounting_app:replace-with-a-long-random-secret@localhost:5432/AI-accounting
